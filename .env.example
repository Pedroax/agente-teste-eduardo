# LLM (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Gerenciamento de contexto
# Estratégia: trim | summarize | none
CONTEXT_STRATEGY=trim

# === TRIM ===
# Mantém as N mensagens mais recentes, descarta as antigas.
# Custo: zero (sem chamada LLM extra)
# Trade-off: perde contexto antigo
TRIM_KEEP_MESSAGES=10

# === SUMMARIZE ===
# Sumariza mensagens antigas quando excede o limite de tokens.
# Custo: uma chamada LLM extra por sumarização
# Trade-off: preserva contexto, mas com custo

# Tokens antes de acionar sumarização
SUMMARIZE_TRIGGER_TOKENS=4000

# Mensagens recentes a manter após sumarização
SUMMARIZE_KEEP_MESSAGES=10

# Modelo para sumarização (use um modelo barato/rápido)
SUMMARIZE_MODEL=google/gemini-3-flash-preview
